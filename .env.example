# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── PostgreSQL (App Metadata) ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cricket_eda
POSTGRES_USER=cricket
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://cricket:changeme@localhost:5432/cricket_eda

# ─── DuckDB ──────────────────────────────────────────────────────────────────
DUCKDB_PATH=data/duckdb/cricket.duckdb

# ─── Data Paths ──────────────────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed

# ─── LLM Configuration ───────────────────────────────────────────────────────
# Set LLM_PROVIDER to "ollama" for local or "openai" for hosted
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# For OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
